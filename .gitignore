# Debug logs
.claude/hook-debug.log
.claude/post-pr-monitor-debug.log

# Generated from .claude/settings.local.json.template by build:all
.claude/settings.local.json

# Built executables (can be rebuilt with pnpm build:all)
.claude/*.exe

# Deploy targets (contains local paths; create from deploy-targets.template.json)
scripts/deploy-targets.json

# Node.js
node_modules/

# Python cache
__pycache__/
*.pyc

# Rust build artifacts
src/*/target/

# Runtime generated files
.claude/.session-id
.claude/pr-monitor-state.json
.claude/pr-monitor-state.json.tmp
.claude/scheduled_tasks.lock
