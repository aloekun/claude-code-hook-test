{
  "permissions": {
    "allow": [
      "Bash(pnpm build:hooks)",
      "Bash(cargo test:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-pre-tool-validate.exe\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-post-tool-linter.exe\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-stop-quality.exe\"",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
