{
  "permissions": {
    "allow": [
      "Bash(pnpm build:all)",
      "Bash(pnpm check-ci *)",
      "Bash(cargo test:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-session-start{{EXE_SUFFIX}}\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-user-prompt-feedback-recovery{{EXE_SUFFIX}}\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-pre-tool-validate{{EXE_SUFFIX}}\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-post-tool-linter{{EXE_SUFFIX}}\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-post-tool-comment-lint-rust{{EXE_SUFFIX}}\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-post-tool-jj-op-verify{{EXE_SUFFIX}}\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-stop-tool-call-leak{{EXE_SUFFIX}}\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-stop-quality{{EXE_SUFFIX}}\"",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}/.claude/hooks-stop-feedback-dispatch{{EXE_SUFFIX}}\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
