{
  "permissions": {
    "allow": [
      "Bash(pnpm build:all)",
      "Bash(pnpm check-ci *)",
      "Bash(pnpm create-pr)",
      "Bash(pnpm create-pr *)",
      "Bash(cargo test:*)",
      "Bash(pnpm merge-pr)",
      "Bash(pnpm merge-pr *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-session-start.exe\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-pre-tool-validate.exe\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Replace",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-post-tool-linter.exe\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PROJECT_DIR}}\\.claude\\hooks-stop-quality.exe\"",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
