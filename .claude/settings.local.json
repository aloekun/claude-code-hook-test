{
  "permissions": {
    "allow": [
      "Bash(pnpm build:hooks)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"%CLAUDE_PROJECT_DIR%\\.claude\\hooks-pre-tool-validate.exe\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"%CLAUDE_PROJECT_DIR%\\.claude\\hooks-post-tool-linter.exe\""
          }
        ]
      }
    ]
  }
}
