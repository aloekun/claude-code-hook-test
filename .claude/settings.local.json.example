{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"%CLAUDE_PROJECT_DIR%\\.claude\\validate-command.exe\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
