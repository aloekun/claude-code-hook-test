{
  "name": "claude-code-hook-test",
  "version": "1.0.0",
  "description": "Claude Code hooks testing project",
  "scripts": {
    "build:hooks-pre-tool-validate": "cd .claude/hooks-pre-tool-validate && cargo build --release && cp target/release/hooks-pre-tool-validate.exe ../hooks-pre-tool-validate.exe",
    "build:hooks-post-tool-linter": "cd .claude/hooks-post-tool-linter && cargo build --release && cp target/release/hooks-post-tool-linter.exe ../hooks-post-tool-linter.exe",
    "build:hooks": "npm run build:hooks-pre-tool-validate && npm run build:hooks-post-tool-linter"
  }
}
